testAss() {
    extrn test, printf;
    printf("Assignation\n");
    auto a;

    test((a = 1) == 1, "= 0");
    test((a = 2) == 2, "= 1");
    test((a = 42) == 42, "= 3");

    test((a =+ 5) == 47, "=+ 0");
    test((a =+ 13) == 60, "=+ 1");
    test((a =+ 1) == 61, "=+ 2");

    test((a =- 4) == 57, "=- 0");
    test((a =- 12) == 45, "=- 1");
    test((a =- 10) == 35, "=- 2");

    test((a =* 2) == 70, "=* 0");
    test((a =* 3) == 210, "=* 1");
    test((a =* 10) == 2100, "=* 2");

    test((a =/ 2) == 1050, "=/ 0");
    test((a =/ 5) == 210, "=/ 1");
    test((a =/ 3) == 70, "=/ 2");

    test((a =% 42) == 28, "=% 0");
    test((a =% 12) == 4, "=% 1");

    test((a =<< 4) == 64, "=<< 0");
    test((a =>> 5) == 2, "=>> 2");

    a = 1;
    test((++a) == 2, "++ 0");
    test((++a) == 3, "++ 1");
    test((--a) == 2, "-- 0");
    test((--a) == 1, "-- 1");

    a = 1;
    test((a++) == 1, "0 ++");
    test((a++) == 2, "1 ++");
    test((a--) == 3, "0 --");
    test((a--) == 2, "1 --");
}
